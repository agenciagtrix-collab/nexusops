{
  "name": "AIAgentConversation",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "agent_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "project_id": {
      "type": "string"
    },
    "user_id": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": [
        "single",
        "council"
      ],
      "default": "single"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "archived"
      ],
      "default": "active"
    },
    "message_count": {
      "type": "number",
      "default": 0
    },
    "last_message_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "agent_ids",
    "user_id"
  ]
}